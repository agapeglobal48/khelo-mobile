{
  "expo": {
    "name": "The Next Olympian",
    "slug": "tno-mobile",
    "scheme": "tno",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0A",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thenextolympian.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.thenextolympian.app",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "jsEngine": "hermes",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "allowBackup": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow The Next Olympian to access your camera to record sports videos.",
          "microphonePermission": "Allow The Next Olympian to access your microphone to record video audio."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ea421fe5-8b78-4a9a-af24-72826c9813d5"
      }
    }
  }
}
