{
  "expo": {
    "name": "Khelo Punjab",
    "slug": "khelo-punjab",
    "owner": "agapeglobal",
    "scheme": "khelo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080E0A",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#062510"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.khelopunjab.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080E0A"
      },
      "package": "com.khelopunjab.app",
      "versionCode": 1,
      "jsEngine": "hermes",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Khelo Punjab to access your camera to record sports videos.",
          "microphonePermission": "Allow Khelo Punjab to access your microphone to record video audio."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      "expo-font",
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "05bd7090-67a0-4057-8277-edd4b836de35"
      }
    }
  }
}
